# SMIT Portal configuration
# Copy this file to .env.local and fill in real values, then restart the dev server.

# ── MongoDB ──────────────────────────────────────────────────
# Use the expanded non-SRV connection string (not mongodb+srv://) — see
# lib/mongodb.ts for why.
MONGODB_URI=

# ── Auth ─────────────────────────────────────────────────────
# Any long random string — signs session cookies (HS256 JWT).
AUTH_JWT_SECRET=

# ── Saylani Intelligence (AI agent) ─────────────────────────
# Get free keys at https://console.groq.com/keys
GROQ_API_KEY=
# Optional second key (different account) — automatic failover when key 1
# hits its rate limit or errors.
GROQ_API_KEY_2=

# ── Voice (optional) ─────────────────────────────────────────
# Get a key at https://elevenlabs.io — without it, voice replies fall back
# to the browser's built-in speech synthesis.
ELEVENLABS_API_KEY=
