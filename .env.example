# SMIT Portal configuration
# Copy this file to .env.local and fill in real values, then restart the dev server.

# ── MongoDB ──────────────────────────────────────────────────
# Use the expanded non-SRV connection string (not mongodb+srv://) — see
# lib/mongodb.ts for why.
MONGODB_URI=

# ── Auth ─────────────────────────────────────────────────────
# Any long random string — signs session cookies (HS256 JWT).
AUTH_JWT_SECRET=

# ── Saylani Intelligence (AI agent) ─────────────────────────
# The agent tries OpenRouter first, then falls back to Groq. Configure at
# least one; both is best (OpenRouter for quality + huge context, Groq as a
# free safety net).
#
# OpenRouter — primary. Runs gpt-5.6-sol (1M-token context, strong tool
# calling, no 8k/min throttle). PAID: add credits at https://openrouter.ai/credits
OPENROUTER_API_KEY=
# Optional second OpenRouter key — automatic failover.
OPENROUTER_API_KEY_2=
# Optional model override (default: openai/gpt-5.6-sol)
OPENROUTER_MODEL=
#
# Groq — fallback. Free keys at https://console.groq.com/keys
# Free tier is capped at 8000 tokens/minute, so it's the safety net, not the
# primary. gpt-oss-120b is the model used here.
GROQ_API_KEY=
# Optional second Groq key (different account) — automatic failover.
GROQ_API_KEY_2=

# ── Voice (optional) ─────────────────────────────────────────
# Get a key at https://elevenlabs.io — without it, voice replies fall back
# to the browser's built-in speech synthesis.
ELEVENLABS_API_KEY=
